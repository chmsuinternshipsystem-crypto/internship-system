{
  "build": {
    "builder": "NIXPACKS",
    "nixpacksConfig": {
      "phpVersion": "8.2",
      "composerVersion": "2"
    }
  },
  "deploy": {
    "numReplicas": 1,
    "startCommand": "php artisan serve --host=0.0.0.0 --port=$PORT",
    "healthcheckPath": "/",
    "restartPolicyType": "ON_FAILURE"
  }
}
